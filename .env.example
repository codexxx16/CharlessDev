# ============================================================
# CharlessDev - Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values

# --- Supabase (Required for blog views, likes, guestbook) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- GitHub (Optional - for live GitHub stats on dashboard) ---
GITHUB_TOKEN=your-github-personal-access-token

# --- Umami Analytics (Optional) ---
NEXT_PUBLIC_UMAMI_URL=https://your-umami-instance.com
NEXT_PUBLIC_UMAMI_WEBSITE_ID=your-website-id

# --- Discord Notifications (Optional - for guestbook alerts) ---
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# --- Site URL ---
NEXT_PUBLIC_SITE_URL=https://charlessdev.vercel.app
